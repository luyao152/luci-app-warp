START=99
STOP=10
USE_PROCD=1

USQUE_BIN="/usr/bin/usque"
CONFIG_FILE="/etc/warp/config.json"
SOCKS_PID_FILE="/var/run/warp-socks.pid"

start_service() {
    config_load warp
    config_get ENABLED config enabled 0
    [ "$ENABLED" != "1" ] && return 0
    
    if [ ! -x "$USQUE_BIN" ]; then
        logger -t warp "Found no usque binary at $USQUE_BIN"
        return 1
    fi

    if [ ! -f "$CONFIG_FILE" ]; then
        logger -t warp "Found no warp config.json. Please register first."
        return 1
    fi
    
    # 获取配置
    config_get ADDRESS_V4 config address_v4 ""
    config_get ADDRESS_V6 config address_v6 ""
    config_get ENDPOINT config endpoint "engage.cloudflareclient.com:2408"
    
    config_get SOCKS_ENABLED config socks_enabled "1"
    config_get SOCKS_PORT config socks_port "1080"
    
    mkdir -p /var/run/warp
    
    # 启动 usque 进程
    procd_open_instance "usque"
    procd_set_param command "$USQUE_BIN" nativetun -c "$CONFIG_FILE"
    procd_set_param respawn
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
    
    logger -t warp "Started usque nativetun"
    
    # 异步添加路由�?SOCKS5
    (
        # 等待 usque 创建 tun 接口
        local max_wait=30
        local count=0
        local USQ_IF=""
        
        while [ $count -lt $max_wait ]; do
            USQ_IF=$(ip link show | grep 'tun' | awk -F': ' '{print $2}' | grep -E '^tun[0-9]+' | head -n 1)
            [ -n "$USQ_IF" ] && break
            sleep 1
            count=$((count + 1))
        done
        
        if [ -z "$USQ_IF" ]; then
            logger -t warp "Failed to find usque tun interface after $max_wait seconds."
            exit 1
        fi

        logger -t warp "usque interface created: $USQ_IF"

        # 4. 配置接口 IP (有些版本不会自动配置)
        [ -n "$ADDRESS_V4" ] && ip addr add "$ADDRESS_V4/32" dev "$USQ_IF" 2>/dev/null
        [ -n "$ADDRESS_V6" ] && ip addr add "$ADDRESS_V6/128" dev "$USQ_IF" 2>/dev/null
        ip link set "$USQ_IF" up

        # 解析 endpoint IP (用于排除路由)
        local end_host="${ENDPOINT%:*}"
        local wan_gw=$(ip route show default | grep -v "$USQ_IF" | awk '{print $3}' | head -1)

        if [ -n "$wan_gw" ]; then
            # 使用多种方式尝试解析以提高成功率
            local end_ip=$(nslookup "$end_host" 2>/dev/null | grep Address | awk '{print $2}' | tail -1)
            [ -z "$end_ip" ] && end_ip=$(resolveip -4 "$end_host" 2>/dev/null | head -1)

            # 添加指向 Cloudflare Endpoint 的直连防环路
            if [ -n "$end_ip" ]; then
                ip route add "$end_ip/32" via "$wan_gw" 2>/dev/null
                logger -t warp "Added direct route to endpoint $end_ip via $wan_gw"
            fi
        fi

        
        # 添加默认路由 (全局代理模式)
        config_get GLOBAL_PROXY config global_proxy 1
        if [ "$GLOBAL_PROXY" = "1" ]; then
            ip route add 0.0.0.0/1 dev "$USQ_IF"
            ip route add 128.0.0.0/1 dev "$USQ_IF"
        fi
        
        # 记录当前�?tun 接口名以便后续清�?
        echo "$USQ_IF" > /var/run/warp/tun_iface
        
        # 5. 防火�?(简单的伪装)
        iptables -t nat -A POSTROUTING -o "$USQ_IF" -j MASQUERADE
        
        # 6. SOCKS5 代理
        if [ "$SOCKS_ENABLED" = "1" ]; then
            if command -v microsocks >/dev/null 2>&1; then
                # �?microsocks 经由 USQUE 接口的本�?IP 提供代理服务
                microsocks -i 0.0.0.0 -p "$SOCKS_PORT" -b "$ADDRESS_V4" &
                echo $! > "$SOCKS_PID_FILE"
                logger -t warp "Started microsocks on port $SOCKS_PORT"
            fi
        fi
    ) &
}

stop_service() {
    config_load warp
    config_get ENDPOINT config endpoint "engage.cloudflareclient.com:2408"

    # 1. 查找运行时的接口名
    local USQ_IF=""
    if [ -f "/var/run/warp/tun_iface" ]; then
        USQ_IF=$(cat /var/run/warp/tun_iface)
    else
        # fallback
        USQ_IF=$(ip link show | grep 'tun' | awk -F': ' '{print $2}' | grep -E '^tun[0-9]+' | head -n 1)
    fi

    # 2. 清理 SOCKS 进程
    if [ -f "$SOCKS_PID_FILE" ]; then
        kill $(cat "$SOCKS_PID_FILE") 2>/dev/null
        rm -f "$SOCKS_PID_FILE"
    fi
    killall microsocks >/dev/null 2>&1

    # 3. 清理路由与防火墙
    if [ -n "$USQ_IF" ]; then
        ip route del 0.0.0.0/1 dev "$USQ_IF" >/dev/null 2>&1
        ip route del 128.0.0.0/1 dev "$USQ_IF" >/dev/null 2>&1
        iptables -t nat -D POSTROUTING -o "$USQ_IF" -j MASQUERADE >/dev/null 2>&1
    fi

    # 清理 endpoint 直连路由
    local end_host="${ENDPOINT%:*}"
    local end_ip=$(nslookup "$end_host" 2>/dev/null | grep Address | awk '{print $2}' | tail -1)
    [ -z "$end_ip" ] && end_ip=$(resolveip -4 "$end_host" 2>/dev/null | head -1)
    [ -n "$end_ip" ] && ip route del "$end_ip/32" >/dev/null 2>&1

    rm -f /var/run/warp/tun_iface
    logger -t warp "Service stopped"
}


reload_service() {
    stop_service
    start_service
}